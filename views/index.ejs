<div class="mainContainer">
  <h1 class="page-title">Welcome to CSE Motors!</h1>

  <!-- Featured Vehicle -->
  <div class="featured-car">
    <div class="carContent">
      <div class='carDetails'>
        <h2 class="car-name">DMC Delorean</h2>
        <ul class="features-list">
          <li>3 Cup holders</li>
          <li>Superman doors</li>
          <li>Fuzzy dice</li>
        </ul>
        <button class="own-btn">Own Today</button>
      </div>
      <div class="car-image-wrapper">
        <img src="/images/vehicles/delorean.jpg" alt="DMC Delorean featured vehicle" class='vehicleImg'>
      </div>
    </div>
  </div>

  <!-- Two column layout on large screens: upgrades left, reviews right -->
  <div class="content-wrapper">
    <!-- Reviews Section - comes first in source so it appears on top on mobile -->
    <div class="reviews-container">
      <h2>DMC Delorean Reviews</h2>
      <ul class="reviews-list">
        <li>"So fast it's almost like traveling in time." (4/5)</li>
        <li>"Coolest ride on the road." (4/5)</li>
        <li>"I'm feeling McFly!" (5/5)</li>
        <li>"The most futuristic ride of our day." (4.5/5)</li>
        <li>"80's livin and I love it!" (5/5)</li>
      </ul>
    </div>

    <!-- Upgrades Section -->
    <div class="upgrades-section">
      <h2 class='upgrade-title'>Delorean Upgrades</h2>
      <div class='upgrades-grid'>
        <div class="upgrade-card">
          <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor upgrade">
          <p><a href="#">Flux Capacitor</a></p>
        </div>
        <div class="upgrade-card">
          <img src="/images/upgrades/flame.jpg" alt='Flame Decals'>
          <p><a href="#">Flame Decals</a></p>
        </div>
        <div class="upgrade-card">
          <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper Stickers">
          <p><a href="#">Bumper Stickers</a></p>
        </div>
        <div class="upgrade-card">
          <img src="/images/upgrades/hub-cap.jpg" alt="Hub Caps for Delorean">
          <p><a href="#">Hub Caps</a></p>
        </div>
      </div>
    </div>
  </div>
</div>
